{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "pnpm --filter @workspace/mt5-trader run export:web && tsx ./build.ts",
    "build:replit": "node --import tsx ./build.ts",
    "start": "NODE_ENV=production tsx ./src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "playwright test"
  },
  "dependencies": {
    "@clerk/express": "2.1.21",
    "@clerk/shared": "4.13.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "drizzle-orm": "catalog:",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "http-proxy-middleware": "4.0.0",
    "jsonwebtoken": "9.0.3",
    "metaapi.cloud-sdk": "29.3.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/bcryptjs": "3.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "tsx": "catalog:",
    "vitest": "4.1.7"
  }
}
