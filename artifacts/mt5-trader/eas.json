{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://workspaceapi-server-production-4768.up.railway.app/api",
        "npm_config_user_agent": "pnpm/10.0.0"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://workspaceapi-server-production-4768.up.railway.app/api",
        "npm_config_user_agent": "pnpm/10.0.0"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false,
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://workspaceapi-server-production-4768.up.railway.app/api",
        "npm_config_user_agent": "pnpm/10.0.0"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "dylcro2@hotmail.co.uk",
        "ascAppId": "6775834658",
        "appleTeamId": "YYW63V8J85"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
