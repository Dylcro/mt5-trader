{
  "expo": {
    "name": "XAUUSD Trader",
    "slug": "mt5-trader",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mt5trader",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "privacy": "unlisted",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xauusdtrader.app",
      "buildNumber": "1",
      "appleTeamId": "PLACEHOLDER_APPLE_TEAM_ID",
      "infoPlist": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "backgroundColor": "#0A0A0A",
      "package": "com.xauusdtrader.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "name": "XAUUSD Trader",
      "shortName": "XAUUSD",
      "description": "Gold trading via MetaTrader 5 with cascade ladder orders",
      "themeColor": "#B8860B",
      "backgroundColor": "#0A0A0A",
      "display": "standalone",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://meta-trader-link.replit.app/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://meta-trader-link.replit.app/privacy"
    }
  }
}
