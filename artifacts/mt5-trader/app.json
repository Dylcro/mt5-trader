{
  "expo": {
    "name": "XAUUSD Trader",
    "slug": "mt5-trader",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mt5trader",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "privacy": "unlisted",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xauusdtrader.app",
      "buildNumber": "1",
      "appleTeamId": "YYW63V8J85",
      "infoPlist": {
        "NSPrivacyAccessedAPITypes": [],
        "NSFaceIDUsageDescription": "Used to protect access to your trading account.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "backgroundColor": "#0A0A0F",
      "package": "com.xauusdtrader.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "name": "XAUUSD Trader",
      "shortName": "XAUUSD",
      "description": "Gold trading via MetaTrader 5 with cascade ladder orders",
      "themeColor": "#C9A84C",
      "backgroundColor": "#0A0A0F",
      "display": "standalone",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://workspaceapi-server-production-4768.up.railway.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C9A84C",
          "defaultChannel": "tp-alerts"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://workspaceapi-server-production-4768.up.railway.app/privacy",
      "eas": {
        "projectId": "75a8d989-e5ce-4c47-b55e-50977b95fca7"
      }
    },
    "owner": "dylcro"
  }
}
